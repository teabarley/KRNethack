#
#	"표준" 3.1 넷핵을 위한 던전 설명(description) 파일입니다.
#
#	참고:	이 파일에서 던전이 정의되는 순서는
#		실제 던전이 생성되는 순서를 반영합니다.
#		"Main(메인)" 분기(branch)는 *반드시* 맨 처음에 와야 합니다.
#		또한 이 파일의 던전 순서가
#		분기 층(branch levels)이 할당되는 순서를 결정한다는 점에 유의하세요.
#		만약 두 던전의 진입점 범위가 겹친다면,
#		분기 층에 대한 선택의 수가 _가장 적은_ 던전을
#		_먼저_ 나열해야 합니다.
#

DUNGEON:	"The Dungeons of Doom" "D" (25, 5)
ALIGNMENT:	unaligned
BRANCH:		"The Gnomish Mines" @ (2, 3)
LEVEL:		"rogue" "R" @ (15, 4)
LEVELDESC:	roguelike
LEVEL:		"oracle" "O" @ (5, 5)
LEVALIGN:	neutral
CHAINBRANCH:	"Sokoban" "oracle" + (1, 0) up
RNDLEVEL:	"bigrm" "B" @ (10, 3) 40 10
CHAINBRANCH:	"The Quest" "oracle" + (6, 2) portal
BRANCH:		"Fort Ludios" @ (18, 4) portal
RNDLEVEL:	"medusa" "none" @ (-5, 4) 4
LEVALIGN:	chaotic
LEVEL:		"castle" "none" @ (-1, 0)
CHAINBRANCH:	"Gehennom" "castle" + (0, 0) no_down
BRANCH:		"The Elemental Planes" @ (1, 0) no_down up

#
#	게헨놈
#
#	이제 3.1 버전을 위해 재작업되었으며, 지옥이 조금 덜
#	지루해지기를 바랍니다. 또한 3.1에서는 탑(tower)이 지옥의 
#	일부로 간주되지 않고, 별도의 던전으로 설정됩니다.
#
#	게헨놈은 더 이상 전체 던전으로서 "지옥 같은(hellish)" 것으로 간주되지 않습니다.
#	즉, 화염 저항이 더 이상 그곳에서의 생존을 위한 필수 조건이 
#	아닙니다. 하지만 게헨놈, 그리고 그곳의 특수 층들은 특히
#	불 함정(fire traps)이 풍부합니다. 결과적으로 화염 저항은 게헨놈에서
#	여전히 신중하고 필수적인 생존 전략입니다.
#
#	참고:	게헨놈은 특정 상황에서 몬스터들이 이곳으로 적절하게 
#		이동(migrate)할 수 있도록 *반드시* 
#		두 번째로 정의되는 던전이어야 합니다.
#
DUNGEON:	"Gehennom" "G" (20, 5)
DESCRIPTION:	mazelike
DESCRIPTION:	hellish
ALIGNMENT:	noalign
BRANCH:		"Vlad's Tower" @ (9, 5) up
LEVEL:		"valley" "V" @ (1, 0)
LEVEL:		"sanctum" "none" @ (-1, 0)
LEVEL:		"juiblex" "J" @ (4, 4)
LEVEL:		"baalz" "B" @ (6, 4)
LEVEL:		"asmodeus" "A" @ (2, 6)
LEVEL:		"wizard1" "none" @ (11, 6)
CHAINLEVEL:	"wizard2" "X" "wizard1" + (1, 0)
CHAINLEVEL:	"wizard3" "Y" "wizard1" + (2, 0)
LEVEL:		"orcus" "O" @ (10, 6)
LEVEL:		"fakewiz1" "F" @ (-6,4)
LEVEL:		"fakewiz2" "G" @ (-6,4)

#
#	취리히 노움들의 광산.
#
DUNGEON:	"The Gnomish Mines" "M" (8, 2)
ALIGNMENT:	lawful
DESCRIPTION:	mazelike
RNDLEVEL:	"minetn" "T" @ (3, 2) 7
LEVELDESC:	town
RNDLEVEL:	"minend" "E" @ (-1, 0) 3

#
#	퀘스트 던전
#
#	이것은 프로토-던전(proto-dungeon)입니다. 층(level) 파일 이름은 초기화 중에
#	"x"를 대체하여 3글자 직업(role) 약어가 앞에 붙게 됩니다.
#	층 설명 파일에 특수한 "x-fill" 층이 반드시 정의되어야 합니다.
#	이 층은 아래에 명시적으로 정의되지 않은 모든 층에 사용될 것입니다.
#
DUNGEON:	"The Quest" "Q" (5, 2)
LEVEL:	"x-strt" "none" @ (1, 1)
LEVEL:	"x-loca" "L" @ (3, 1)
LEVEL:	"x-goal" "none" @ (-1, 0)

#
# 소코반
#
DUNGEON:		"Sokoban" "none" (4, 0)
DESCRIPTION:    mazelike
ALIGNMENT:      neutral
ENTRY:          -1
RNDLEVEL:		"soko1" "none" @ (1, 0) 2
RNDLEVEL:		"soko2" "none" @ (2, 0) 2
RNDLEVEL:		"soko3" "none" @ (3, 0) 2
RNDLEVEL:		"soko4" "none" @ (4, 0) 2

#
#	크로이소스의 중앙 금고.
#
DUNGEON:	"Fort Ludios" "K" (1, 0)
DESCRIPTION:	mazelike
ALIGNMENT:	unaligned
LEVEL:		"knox" "K" @ (-1, 0)
#
#	블라드의 탑
#
#	이곳은 게헨놈에서 제거되었으며, 돌(stone)로 둘러싸여 있습니다.
#	이곳의 최상층에서는 뼈(bones) 파일이 생성되지 않도록 해야 합니다.
#
DUNGEON:	"Vlad's Tower" "T" (3, 0)
PROTOFILE:	"tower"
DESCRIPTION:	mazelike
ALIGNMENT:	chaotic
ENTRY:		-1
LEVEL:		"tower1" "none" @ (1, 0)
# 이 마지막 두 개를 굳이 나열할 필요는 없지만, 이렇게 하면
# ^O 출력 화면과 레벨 텔레포트 메뉴에 나타나게 됩니다.
LEVEL:		"tower2" "none" @ (2, 0)
LEVEL:		"tower3" "none" @ (3, 0)

#
#	엔드게임(Endgame) 층
#
#	밑에서부터 두 번째 층에서 진입합니다; 밑에서 1번째 층은
#	지상 층을 위한 자리 표시자(placeholder)이며, 접근할 수 없어야 합니다.
#	[참고: "dummy"라는 이름은 init_dungeons()에서 확인됩니다.]
#
DUNGEON:	"The Elemental Planes" "E" (6, 0)
DESCRIPTION:	mazelike
ALIGNMENT:	unaligned
ENTRY:		-2
LEVEL:		"astral" "none" @ (1, 0)
LEVEL:		"water"  "none" @ (2, 0)
LEVEL:		"fire"   "none" @ (3, 0)
LEVEL:		"air"    "none" @ (4, 0)
LEVEL:		"earth"  "none" @ (5, 0)
LEVEL:		"dummy"  "none" @ (6, 0)
